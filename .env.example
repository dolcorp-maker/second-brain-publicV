# ══════════════════════════════════════════════════════════════════════════════
#  Second Brain Bot — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit your .env file — it contains real secrets.
# ══════════════════════════════════════════════════════════════════════════════


# ── REQUIRED — Bot will refuse to start without these ─────────────────────────

# Telegram bot token — create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID — restricts the bot to only respond to you.
# Find it by messaging @userinfobot on Telegram.
# Leave blank to allow all users (NOT recommended for personal use).
ALLOWED_USER_ID=

# Anthropic API key — used for Claude (complex queries, tool use)
# Get it at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini API key — used for Gemini (simple/free queries)
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Dashboard login password — protects the web dashboard from public access
DASHBOARD_PASSWORD=

# Flask session secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Your server's local IP address (e.g. 192.168.1.x)
# Run `hostname -I` on your server to find it.
SERVER_IP=


# ── NETWORK — LAN dashboard access ────────────────────────────────────────────

# IP prefix for your local network. Clients matching this prefix get the full
# dashboard without login. Leave blank to require login from all IPs.
# Example: LAN_SUBNET=192.168.1.
LAN_SUBNET=


# ── PERSONALISATION ────────────────────────────────────────────────────────────

# Your local timezone — used in AI prompts and Google Calendar events.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: America/New_York, Europe/London, Asia/Tokyo, Asia/Jerusalem
TIMEZONE=UTC

# Your city — used as the default city for /weather and AI weather queries.
USER_CITY=London

# Your home address — used as the default origin in Google Maps navigation.
# Example: 123 Main St, Springfield, USA
HOME_ADDRESS=


# ── SEARCH & WEATHER ──────────────────────────────────────────────────────────

# Brave Search API key — used for web_search tool
# Get it at: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# OpenWeatherMap API key — used for get_weather tool
# Get it at: https://openweathermap.org/api (free tier is enough)
OPENWEATHER_API_KEY=


# ── OPTIONAL — Required only for specific features ────────────────────────────

# OpenAI API key — only used as a Whisper transcription fallback if
# faster-whisper fails. Not needed if ENABLE_VOICE=false.
OPENAI_API_KEY=


# ══════════════════════════════════════════════════════════════════════════════
#  FEATURE FLAGS
#  Set to "false" to disable a feature and skip its setup entirely.
#  Disabled tools are excluded from the AI tool list — the AI won't try to use them.
# ══════════════════════════════════════════════════════════════════════════════

# Google Calendar, Gmail, and Google Tasks integration.
# Requires credentials.json from Google Cloud Console + running authorize_google.py.
# See: https://console.cloud.google.com/ → APIs & Services → Credentials
ENABLE_GOOGLE=true

# Voice message transcription (faster-whisper, local, free).
# Requires: pip install faster-whisper  AND  ffmpeg installed on your system.
# setup.sh handles this automatically if ENABLE_VOICE=true.
ENABLE_VOICE=true

# Text-to-speech voice replies (gTTS, free, no API key needed).
# Triggered when the user says "speak", "read me", "out loud", etc.
# Requires: pip install gtts
ENABLE_TTS=true

# Maccabi Haifa FC match schedule scraper (no API key needed).
# Scrapes the official website — disable if you don't follow Israeli football.
ENABLE_MACCABI=true

# AI video/GIF generation via Google Veo 3 (requires Gemini API key above).
# Generated GIFs are stored in data/videos/. Takes ~30-60 seconds per request.
ENABLE_VIDEO=true
